{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "main": "src/app.ts",
  "types": "src/app.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.0",
    "@elysiajs/cors": "^1.4.0",
    "drizzle-orm": "^0.44.0",
    "elysia": "^1.4.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
